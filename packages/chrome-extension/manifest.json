{
  "manifest_version": 3,
  "name": "Generador de CV Profesional",
  "short_name": "CV Generator",
  "version": "1.0.0",
  "description": "Genera CV profesionales en PDF desde un archivo YAML. Offline y gratuito.",
  "author": "Donshu",
  "homepage_url": "https://github.com/donshuapps-cloud/cv-generator-monorepo",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Generar CV",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": false
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "downloads",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://cdn.jsdelivr.net/*",
    "https://cdnjs.cloudflare.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "offline_enabled": true,
  "minimum_chrome_version": "88",
  "default_locale": "es"
}
